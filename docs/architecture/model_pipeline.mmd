flowchart TB
  manifest["CALVIN or mock manifests"] --> window["Window dataset"]
  window --> batch["rgb_hist, proprio_hist, lang, past_actions, action_chunk, future_clip"]
  batch --> cache["VideoWorld2 local-code cache"]
  cache --> future["GT future_codes / future_code_embeds<br/>(privileged upper bound)"]
  batch --> state["StateEncoder"]
  state --> planner["LatentPlanner (optional predicted-code branch)"]
  planner --> pred["predicted code embeds<br/>(implemented; no published Phase 1 claim)"]
  state --> idm["HistoryAwareIDM / DirectPolicy / MLPActionHead"]
  future --> idm
  pred --> idm
  batch --> idm
  idm --> actions["Gaussian action chunk"]
  actions --> offline["offline NLL / MSE / jerk"]
  actions --> mock["mock-only closed-loop smoke"]
  offline --> status["gate status"]
  mock --> status
